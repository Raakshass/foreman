# ── CROO / CAP network ───────────────────────────────────────────
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# One SDK key per registered agent (from agent.croo.network -> My Agents -> Configure).
# Each key is shown ONLY ONCE at registration -- save it immediately.
FOREMAN_SDK_KEY=croo_sk_...
ECHO_WORKER_SDK_KEY=croo_sk_...
RESEARCH_WORKER_SDK_KEY=croo_sk_...

# serviceId of each worker's listed service (visible on the Agent Store / dashboard
# after you register the service under that agent). Foreman hires these serviceIds.
ECHO_WORKER_SERVICE_ID=
RESEARCH_WORKER_SERVICE_ID=

# ── Claude (planner + verifier brains) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ── Reputation sink (swap to on-chain once Person B ships the contract) ──
REPUTATION_MODE=local
# REPUTATION_MODE=onchain
REPUTATION_RPC_URL=
REPUTATION_CONTRACT_ADDRESS=
REPUTATION_WRITER_PRIVATE_KEY=
